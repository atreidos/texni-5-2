# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Master's Telegram chat_id (for notifications)
MASTER_CHAT_ID=your_master_chat_id_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Google Calendar
# Path to service account JSON file (or JSON string for Railway)
GOOGLE_CREDENTIALS_JSON=path/to/credentials.json
CALENDAR_SLOTS_ID=your_slots_calendar_id@group.calendar.google.com
CALENDAR_BOOKINGS_ID=your_bookings_calendar_id@group.calendar.google.com

# AI module (reserved for v2)
AI_ENABLED=false
